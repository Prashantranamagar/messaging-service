    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Delivery status webhook",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const body = pm.request.body.raw;",
                  "const secret = pm.variables.get(\"webhookSecret\");",
                  "",
                  "const signature = CryptoJS.HmacSHA256(body, secret)",
                  "    .toString(CryptoJS.enc.Hex);",
                  "",
                  "pm.request.headers.upsert({",
                  "    key: \"X-Signature\",",
                  "    value: signature",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Signature",
                "value": ""
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"provider_message_id\":\"mock_b415723fbc1f4587\",\"status\":\"delivered\",\"reason\":\"provider accepted\",\"occurred_at\":\"2026-07-07T12:00:00Z\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhooks/delivery-status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "webhooks",
                "delivery-status"
              ]
            },
            "description": "Populate the X-Signature header with a SHA-256 HMAC using the webhook secret and the raw request body."
          },
          "response": []
        }
      ]
