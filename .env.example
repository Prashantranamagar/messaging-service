# --- App ---
APP_NAME=messaging-platform
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Security ---
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
API_KEY_HEADER=X-API-Key
VALID_API_KEYS=dev-key-1,dev-key-2
WEBHOOK_HMAC_SECRET=change-me-in-production

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Database ---
DATABASE_URL=postgresql+psycopg://messaging:messaging@postgres:5432/messaging
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_ECHO=false

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_MAX_RETRIES=5
CELERY_TASK_RETRY_BACKOFF=5

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=120

# --- Bulk import ---
BULK_IMPORT_MAX_FILE_SIZE_MB=25
BULK_IMPORT_MAX_ROWS=200000
BULK_IMPORT_BATCH_SIZE=1000

# --- Messaging / providers ---
DEFAULT_MESSAGE_CHANNEL=sms
PROVIDER_NAME=mock
MESSAGE_SEND_MAX_RETRIES=3
MESSAGE_SEND_RETRY_BACKOFF=10

# --- Notifications ---
NOTIFICATION_WEBHOOK_TIMEOUT_SECONDS=5
NOTIFICATION_MAX_RETRIES=5
